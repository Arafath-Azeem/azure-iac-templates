{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus"
    },
    "subnetId": {
      "value": "/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.Network/virtualNetworks/<vnet>/subnets/<subnet>"
    },
    "lbPrivateIp": {
      "value": "10.0.1.10"
    },
    "lbName": {
      "value": "my-load-balancer"
    },
    "frontendName": {
      "value": "frontend-ip"
    },
    "backendPoolName": {
      "value": "backend-pool"
    },
    "backendIpAddresses": {
      "value": [
        "10.0.1.20",
        "10.0.1.21",
        "10.0.1.22"
      ]
    },
    "tags": {
      "value": {
        "Environment": "Production"
      }
    }
  }
}